# App — genera un valor seguro: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-jwt-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Base de datos
# Local (SQLite para desarrollo sin Docker):  sqlite:///./prosperas.db
# Local (Postgres via Docker):               postgresql://user:pass@postgres:5432/prosperas
# Producción (RDS):                          postgresql://user:pass@rds-host:5432/prosperas
DATABASE_URL=sqlite:///./prosperas.db

# AWS — credenciales
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_DEFAULT_REGION=us-east-1
# Solo en local con LocalStack — comentar en producción
AWS_ENDPOINT_URL=http://localstack:4566

# SQS
SQS_QUEUE_URL=http://localstack:4566/000000000000/prosperas-jobs
SQS_DLQ_URL=http://localstack:4566/000000000000/prosperas-jobs-dlq

# S3
S3_BUCKET_NAME=prosperas-reports

# Worker
WORKER_CONCURRENCY=4
SQS_VISIBILITY_TIMEOUT=120
SQS_MAX_MESSAGES=10
SQS_WAIT_SECONDS=20

# Frontend (solo si usas Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
